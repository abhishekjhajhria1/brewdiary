# brewdiary — AI bartender provider (any OpenAI-compatible chat API).
# Copy to .env.local and fill in. WITHOUT a key, the bartender still works on
# built-in scripted suggestions. The key is read server-side only (never shipped
# to the browser). Pick whichever provider is cheapest for you — code is identical.

# Required to go live:
AI_API_KEY=

# Provider endpoint + model. Default = Groq: it is the chosen TEACHER model
# while we distill our own Ninkasi (see scripts/ninkasi/README.md) — cheap,
# fast, and its answers accumulate (with user consent) into ninkasi_exchanges,
# the corpus our own fine-tuned model trains on. When that model is hosted,
# point AI_BASE_URL/AI_MODEL at it — nothing else changes.
#
#   Groq (teacher)  AI_BASE_URL=https://api.groq.com/openai/v1
#                   AI_MODEL=llama-3.3-70b-versatile
#
#   Our own Ninkasi AI_BASE_URL=https://<your-vllm-or-together-host>/v1
#   (student)       AI_MODEL=ninkasi-8b
#
#   xAI Grok        AI_BASE_URL=https://api.x.ai/v1        AI_MODEL=grok-4-fast
#   Google Gemini   AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#                   AI_MODEL=gemini-2.0-flash
#   OpenAI          AI_BASE_URL=https://api.openai.com/v1  AI_MODEL=gpt-4o-mini
#   DeepSeek        AI_BASE_URL=https://api.deepseek.com   AI_MODEL=deepseek-chat
#
# Set AI_MODEL to the exact id your provider uses — they change over time.
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# ── The SEPARATE AI database (the "Ninkasi Data Plane") ──────────────────────
# A SECOND Supabase project, dedicated to the AI's data (the training corpus +
# anonymized trend snapshots). It is reached ONLY from our server, never the browser.
# Apply ai-db/schema.sql in that project, then fill these in (server-side only):
#   AI_SUPABASE_URL          the second project's URL (https://<ref>.supabase.co)
#   AI_SUPABASE_SERVICE_KEY  its service_role key (full access; SERVER-ONLY, never NEXT_PUBLIC)
#   AI_DB_SALT               a long random string — pseudonymizes user ids in the corpus
#                            (set once and NEVER change it, or past rows can't be matched)
# Leave blank and the app runs fine; consented exchanges just aren't recorded centrally yet.
AI_SUPABASE_URL=
AI_SUPABASE_SERVICE_KEY=
AI_DB_SALT=

# Optional: the second project's Postgres connection string, only if you want to run
# DDL from the CLI (node scripts/db.mjs ai-db/schema.sql) instead of the SQL editor.
AI_SUPABASE_DB_URL=
