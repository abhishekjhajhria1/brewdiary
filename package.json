{
  "name": "brewdiary",
  "version": "0.1.0",
  "private": true,
  "description": "An all-inclusive drink diary. Tap a day, log a drink, watch the year quietly fill in.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
